# Copie para .env e preencha conforme o ambiente

# --- setupProxy.js (desenvolvimento) ---
# Target do proxy: para onde /api-service, /api-postgrest e /minio são redirecionados
# Local (backend em localhost): deixe vazio ou não defina
# Produção (conectar ao backend no servidor): defina as URLs completas
# Ex: VITE_API_SERVICE_URL=https://auth-jels.criativesoftware.com.br
# Ex: VITE_POSTGREST_URL=https://api-jels.criativesoftware.com.br
# Ex: VITE_MINIO_URL=https://storage-jels.criativesoftware.com.br
VITE_API_SERVICE_URL=
VITE_POSTGREST_URL=
VITE_MINIO_URL=
