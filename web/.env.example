# ============================================
# Jogos Escolares - Frontend
# ============================================
# Copie para .env e preencha os valores

# API Service (autenticação, modalidades, etc.)
# Desenvolvimento com proxy Vite: use /api-service
# Produção: URL completa ex. https://api.seudominio.com
VITE_API_SERVICE_URL=

# PostgREST (CRUD REST automático)
# Desenvolvimento com proxy Vite: use /postgrest
# Produção: URL completa ex. https://api.seudominio.com/postgrest
VITE_POSTGREST_URL=
